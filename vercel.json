{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": "src/otonom/web/**"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
